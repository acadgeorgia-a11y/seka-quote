# Copy to .env.local and fill in.

# Supabase (browser-safe, anon key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Shared passcode required to access /admin/*
VITE_ADMIN_PASSCODE=

# Where this app is hosted (used for links, share URLs)
VITE_APP_URL=http://localhost:5173

# Supabase Edge Function base URL (usually VITE_SUPABASE_URL/functions/v1)
# Leave blank to derive automatically.
VITE_SUPABASE_FUNCTIONS_URL=

# ---------- Edge Function secrets (set in Supabase dashboard, NOT here) ----------
# GOOGLE_MAPS_API_KEY=
# TOLLGURU_API_KEY=
